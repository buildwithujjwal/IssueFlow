<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IssueFlow - Issue</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
        }

        .navbar {
            background: white;
            padding: 16px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }

        .navbar h1 {
            font-size: 20px;
            color: #1a1a2e;
        }

        .navbar a {
            font-size: 14px;
            color: #4f46e5;
            text-decoration: none;
            font-weight: 600;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .issue-header {
            background: white;
            border-radius: 10px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .issue-header h2 {
            font-size: 22px;
            color: #1a1a2e;
            margin-bottom: 10px;
        }

        .issue-header p {
            font-size: 14px;
            color: #666;
            margin-bottom: 16px;
        }

        .badges {
            display: flex;
            gap: 8px;
        }

        .badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge.open { background: #dbeafe; color: #1d4ed8; }
        .badge.in-progress { background: #fef9c3; color: #854d0e; }
        .badge.resolved { background: #dcfce7; color: #166534; }

        .badge.low { background: #f1f5f9; color: #475569; }
        .badge.medium { background: #fef3c7; color: #92400e; }
        .badge.high { background: #fee2e2; color: #991b1b; }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 16px;
        }

        .comment-card {
            background: white;
            border-radius: 10px;
            padding: 16px 20px;
            margin-bottom: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .comment-card .author {
            font-size: 13px;
            font-weight: 600;
            color: #4f46e5;
            margin-bottom: 6px;
        }

        .comment-card .body {
            font-size: 14px;
            color: #444;
        }

        .comment-form {
            background: white;
            border-radius: 10px;
            padding: 20px 24px;
            margin-top: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .comment-form textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Segoe UI', sans-serif;
            resize: vertical;
            outline: none;
            margin-bottom: 12px;
        }

        .comment-form textarea:focus {
            border-color: #4f46e5;
        }

        .comment-form button {
            padding: 10px 20px;
            background: #4f46e5;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }

        .comment-form button:hover {
            background: #4338ca;
        }

        .empty {
            text-align: center;
            color: #aaa;
            font-size: 14px;
            padding: 20px 0;
        }
    </style>
</head>
<body>

    <div class="navbar">
        <h1>IssueFlow</h1>
        <a id="back-link" href="/dashboard">← Back</a>
    </div>

    <div class="container">

        <div class="issue-header" id="issue-detail">
            <p>Loading...</p>
        </div>

        <div class="section-title">Comments</div>

        <div id="comments-list"></div>

        <div class="comment-form">
            <textarea id="comment-body" rows="3" placeholder="Write a comment..."></textarea>
            <button onclick="addComment()">Post Comment</button>
        </div>

    </div>

    <script>
        function getCookie(name) {
            const value = `; ${document.cookie}`
            const parts = value.split(`; ${name}=`)
            if (parts.length === 2) return parts.pop().split(';').shift()
        }

        const token = getCookie('token')
        const issueId = window.location.pathname.split('/').pop()

        async function loadIssue() {
            const response = await fetch(`/api/issues/${issueId}`, {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            })

            const issue = await response.json()

            document.getElementById('back-link').href = `/projects/${issue.project}`
            document.getElementById('issue-detail').innerHTML = `
                <h2>${issue.title}</h2>
                <p>${issue.description}</p>
                <div class="badges">
                    <span class="badge ${issue.status}">${issue.status}</span>
                    <span class="badge ${issue.priority}">${issue.priority}</span>
                </div>
            `
        }

        async function loadComments() {
            const response = await fetch(`/api/issues/${issueId}/comments`, {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            })

            const comments = await response.json()
            const container = document.getElementById('comments-list')

            if (comments.length === 0) {
                container.innerHTML = '<div class="empty">No comments yet.</div>'
                return
            }

            container.innerHTML = comments.map(function(comment) {
                return `
                    <div class="comment-card">
                        <div class="author">${comment.author.name}</div>
                        <div class="body">${comment.body}</div>
                    </div>
                `
            }).join('')
        }

        async function addComment() {
            const body = document.getElementById('comment-body').value

            if (!body.trim()) return

            await fetch(`/api/issues/${issueId}/comments`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ body })
            })

            document.getElementById('comment-body').value = ''
            loadComments()
        }

        loadIssue()
        loadComments()
    </script>

</body>
</html>