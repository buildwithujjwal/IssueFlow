<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IssueFlow - Issue</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f2f5;
            min-height: 100vh;
        }

        .navbar {
            background: white;
            padding: 16px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }

        .navbar h1 {
            font-size: 20px;
            color: #1a1a2e;
        }

        .navbar a {
            font-size: 14px;
            color: #4f46e5;
            text-decoration: none;
            font-weight: 600;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .issue-header {
            background: white;
            border-radius: 10px;
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .badges {
            display: flex;
            gap: 8px;
            margin-top: 16px;
        }

        .badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge.open { background: #dbeafe; color: #1d4ed8; }
        .badge.in-progress { background: #fef9c3; color: #854d0e; }
        .badge.resolved { background: #dcfce7; color: #166534; }

        .badge.low { background: #f1f5f9; color: #475569; }
        .badge.medium { background: #fef3c7; color: #92400e; }
        .badge.high { background: #fee2e2; color: #991b1b; }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 16px;
        }

        .comment-card {
            background: white;
            border-radius: 10px;
            padding: 16px 20px;
            margin-bottom: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .comment-card .author {
            font-size: 13px;
            font-weight: 600;
            color: #4f46e5;
            margin-bottom: 6px;
        }

        .comment-card .body {
            font-size: 14px;
            color: #444;
        }

        .comment-form {
            background: white;
            border-radius: 10px;
            padding: 20px 24px;
            margin-top: 24px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        .comment-form textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Segoe UI', sans-serif;
            resize: vertical;
            outline: none;
            margin-bottom: 12px;
        }

        .comment-form textarea:focus {
            border-color: #4f46e5;
        }

        .comment-form button {
            padding: 10px 20px;
            background: #4f46e5;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }

        .comment-form button:hover {
            background: #4338ca;
        }

        .edit-btn {
            padding: 8px 16px;
            background: #4f46e5;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
        }

        .edit-btn:hover {
            background: #4338ca;
        }

        .edit-form {
            display: none;
            margin-top: 20px;
            border-top: 1px solid #eee;
            padding-top: 20px;
        }

        .edit-form label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #333;
            margin-bottom: 6px;
        }

        .edit-form input,
        .edit-form textarea,
        .edit-form select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Segoe UI', sans-serif;
            margin-bottom: 16px;
            outline: none;
        }

        .edit-form textarea {
            resize: vertical;
        }

        .empty {
            text-align: center;
            color: #aaa;
            font-size: 14px;
            padding: 20px 0;
        }

        .issue-meta {
            font-size: 13px;
            color: #888;
            margin-top: 8px;
        }
    </style>
</head>
<body>

    <div class="navbar">
        <h1>IssueFlow</h1>
        <a id="back-link" href="/dashboard">← Back</a>
    </div>

    <div class="container">

        <div class="issue-header" id="issue-detail">
            <p>Loading...</p>
        </div>

        <div class="section-title">Comments</div>

        <div id="comments-list"></div>

        <div class="comment-form">
            <textarea id="comment-body" rows="3" placeholder="Write a comment..."></textarea>
            <button onclick="addComment()">Post Comment</button>
        </div>

    </div>

    <script>
        const currentUserId = '<%= user.id %>'

        function getCookie(name) {
            const value = `; ${document.cookie}`
            const parts = value.split(`; ${name}=`)
            if (parts.length === 2) return parts.pop().split(';').shift()
        }

        const token = getCookie('token')
        const issueId = window.location.pathname.split('/').pop()

        async function updateStatus(newStatus) {
            await fetch(`/api/issues/${issueId}`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ status: newStatus })
            })

            loadIssue()
        }

        async function loadIssue() {
            const response = await fetch(`/api/issues/${issueId}`, {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            })

            const issue = await response.json()

            document.getElementById('back-link').href = `/projects/${issue.project}`

            const isAuthor = issue.createdBy && issue.createdBy._id === currentUserId

            const authorName = issue.createdBy ? issue.createdBy.name : 'Unknown'

            document.getElementById('issue-detail').innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                    <div>
                        <h2 style="font-size:22px; color:#1a1a2e;">${issue.title}</h2>
                        <p style="font-size:14px; color:#666; margin-top:8px;">${issue.description}</p>
                        <p class="issue-meta">Reported by <strong>${authorName}</strong></p>
                        <div style="display:flex; align-items:center; gap:8px; margin-top:16px;">
                            <select onchange="updateStatus(this.value)" style="padding:4px 12px; border:1px solid #ddd; border-radius:20px; font-size:12px; font-weight:600; outline:none; cursor:pointer; background:#f8f8f8; color:#333; appearance:none; -webkit-appearance:none;">
                                <option value="open" ${issue.status === 'open' ? 'selected' : ''}>🔵 Open</option>
                                <option value="in-progress" ${issue.status === 'in-progress' ? 'selected' : ''}>🟡 In Progress</option>
                                <option value="resolved" ${issue.status === 'resolved' ? 'selected' : ''}>🟢 Resolved</option>
                            </select>
                            <span class="badge ${issue.priority}">${issue.priority}</span>
                        </div>
                    </div>
                    ${isAuthor ? `<button class="edit-btn" onclick="toggleEditForm()">Edit Issue</button>` : ''}
                </div>

                <div class="edit-form" id="edit-form">

                    <label>Title</label>
                    <input id="edit-title" type="text" value="${issue.title}" />

                    <label>Description</label>
                    <textarea id="edit-desc" rows="3">${issue.description}</textarea>

                    <label>Status</label>
                    <select id="edit-status">
                        <option value="open" ${issue.status === 'open' ? 'selected' : ''}>Open</option>
                        <option value="in-progress" ${issue.status === 'in-progress' ? 'selected' : ''}>In Progress</option>
                        <option value="resolved" ${issue.status === 'resolved' ? 'selected' : ''}>Resolved</option>
                    </select>

                    <label>Priority</label>
                    <select id="edit-priority">
                        <option value="low" ${issue.priority === 'low' ? 'selected' : ''}>Low</option>
                        <option value="medium" ${issue.priority === 'medium' ? 'selected' : ''}>Medium</option>
                        <option value="high" ${issue.priority === 'high' ? 'selected' : ''}>High</option>
                    </select>

                    <button class="edit-btn" onclick="saveIssue()">Save Changes</button>

                </div>
            `
        }

        function toggleEditForm() {
            const form = document.getElementById('edit-form')
            form.style.display = form.style.display === 'none' || form.style.display === '' ? 'block' : 'none'
        }

        async function saveIssue() {
            const title = document.getElementById('edit-title').value
            const description = document.getElementById('edit-desc').value
            const status = document.getElementById('edit-status').value
            const priority = document.getElementById('edit-priority').value

            await fetch(`/api/issues/${issueId}`, {
                method: 'PATCH',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ title, description, status, priority })
            })

            loadIssue()
        }

        async function loadComments() {
            const response = await fetch(`/api/issues/${issueId}/comments`, {
                headers: {
                    'Authorization': `Bearer ${token}`
                }
            })

            const comments = await response.json()
            const container = document.getElementById('comments-list')

            if (comments.length === 0) {
                container.innerHTML = '<div class="empty">No comments yet.</div>'
                return
            }

            container.innerHTML = comments.map(function(comment) {
                return `
                    <div class="comment-card">
                        <div class="author">${comment.author.name}</div>
                        <div class="body">${comment.body}</div>
                    </div>
                `
            }).join('')
        }

        async function addComment() {
            const body = document.getElementById('comment-body').value

            if (!body.trim()) return

            await fetch(`/api/issues/${issueId}/comments`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ body })
            })

            document.getElementById('comment-body').value = ''
            loadComments()
        }

        loadIssue()
        loadComments()
    </script>

</body>
</html>